{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/settings/layout,_N_T_/settings/preferences/layout,_N_T_/settings/preferences/page,_N_T_/settings/preferences"
  },
  "segmentPaths": [
